# Config for the self-hosted GlitchTip backend (docker-compose.yml).
# Copy to `.env` in this directory and edit before running compose.
# POSTGRES_PASSWORD and SECRET_KEY are REQUIRED — compose refuses to start
# without them, so there are no insecure defaults to forget to change.

# Postgres password used by the bundled database.
POSTGRES_PASSWORD=

# Long random string. Generate with: openssl rand -hex 32
SECRET_KEY=

# Public URL where GlitchTip is reachable.
GLITCHTIP_DOMAIN=http://localhost:8000

# Outbound email for invites/alerts. `consolemail://` just logs to stdout.
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=admin@localhost
